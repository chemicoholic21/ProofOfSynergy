# Copy to .env.local. App degrades gracefully if any of these are missing.

# Sarvam (OCR, STT, LLM). Without it, the AI flow uses realistic demo data.
SARVAM_API_KEY=

# Monad chain (server-side mint/attest). Without these, minting returns a labelled fallback.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
DEPLOYER_PRIVATE_KEY=

# Filled after running contracts/deploy.sh:
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_PASSPORT_ADDRESS=
NEXT_PUBLIC_GATE_ADDRESS=
NEXT_PUBLIC_EXPLORER_URL=https://testnet.monadexplorer.com

# Optional: real IPFS pinning. Without it, evidence uses a deterministic mock ipfs:// URI.
PINATA_JWT=
